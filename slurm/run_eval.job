#!/bin/bash
#SBATCH --job-name=rag_baseline
#SBATCH --partition=gpu
#SBATCH --gres=gpu:a40:1             # Request 1 GPU
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8        # CPU cores for the FAISS retrieval
#SBATCH --mem=32GB               # 32GB RAM to hold the FAISS index in memory
#SBATCH --time=24:00:00          # 24 hours max runtime
#SBATCH --output=rag_eval_%j.out # Standard output and error log


module purge
module load ver/2506 gcc/14.3.0 python/3.11.14 



export HF_HOME=/scratch1/$USER/hf_cache
mkdir -p $HF_HOME

#HUGGIN FACE AND PINE CONE 
export HF_TOKEN=$HF_TOKEN
export PINECONE_API_KEY=$PINECONE_API_KEY

which python



echo "Setting up Python environment..."
rm -rf rag_env
python -m venv rag_env
source rag_env/bin/activate


echo "Installing dependencies..."
pip install --upgrade pip
pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu118
pip install -r requirements.txt
#evaluation tools installed
pip install transformers sentence-transformers pinecone faiss-cpu evaluate rouge_score accelerate datasets scikit-learn scipy

export PYTHONPATH=$PYTHONPATH:$(pwd)/src

if [ ! -d "data" ]; then
    echo "ERROR: 'data' folder not found in $(pwd). rag_pipeline_bge's code will fail to load the dataset!"
    exit 1
fi
python src/standard_rag/rag_pipeline_bge.py
echo "Starting evaluation..."
python src/evaluation/evaluate_baseline.py

echo "Job completed."
